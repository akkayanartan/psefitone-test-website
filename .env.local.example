# PayTR Virtual POS credentials
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local. Never commit real keys to .env.local.example.
#
# Source: PayTR merchant panel → Yönetim & Ayarlar → API / Entegrasyon Bilgileri

PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# 1 = test mode (use PayTR test cards only, no real charges)
# 0 = live mode (real charges). Only flip to 0 after smoke-testing.
PAYTR_TEST_MODE=1

# Max installment count shown in PayTR's hosted iframe.
# PayTR will respect merchant-panel installment settings regardless.
PAYTR_MAX_INSTALLMENT=5

# Public values (exposed to the browser). Safe to commit non-secret defaults.
# Single-payment course price in Turkish Lira (integer TL, not kuruş).
NEXT_PUBLIC_COURSE_PRICE_TL=25000

# Absolute origin for building PayTR merchant_ok_url / merchant_fail_url.
# Use the exact Vercel URL in production, http://localhost:3000 locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
